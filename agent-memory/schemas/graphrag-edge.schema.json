{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GraphRagEdge",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "target", "type"],
  "properties": {
    "source": { "type": "string", "pattern": "^mem:" },
    "target": { "type": "string", "minLength": 1 },
    "type": { "type": "string" },
    "reason": { "type": "string" },
    "confidence": { "type": "number" }
  }
}
