{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GlobalUserMemoryRecord",
  "type": "object",
  "additionalProperties": true,
  "required": ["memory_id", "tenant_id", "customer_id", "project_id", "doc_type", "status", "visibility", "data_class", "semantic_title", "summary", "updated_at", "edges"],
  "properties": {
    "memory_id": { "type": "string", "pattern": "^mem:" },
    "tenant_id": { "type": "string", "const": "user-local" },
    "customer_id": { "type": "string", "const": "personal" },
    "project_id": { "type": "string", "const": "global-user-memory" },
    "doc_type": {
      "type": "string",
      "enum": ["user_context", "preference", "goal", "daily", "personal_task", "research", "personal_pattern", "coach_report", "onboarding_profile"]
    },
    "visibility": { "type": "string", "enum": ["private", "shared"] },
    "data_class": { "type": "string", "enum": ["public", "internal", "confidential", "personal", "special-category"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "last_confirmed_at": { "type": "string" },
    "expires_at": { "type": "string" },
    "valid_until": { "type": "string" },
    "edges": { "type": "array" }
  }
}
