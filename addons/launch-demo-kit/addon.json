{
  "name": "launch-demo-kit",
  "version": "0.1.0",
  "description": "Optional five-minute demo assets that show Owledge durable memory, evidence, handoff, and a static proof report.",
  "install_directories": [
    "agent-memory/launch-demo",
    "agent-memory/evidence",
    "agent-memory/handoffs",
    "agent-memory/reports/launch-demo",
    "agent-memory/templates"
  ],
  "install_files": [
    {
      "source": "starter/agent-memory/launch-demo/profile.md",
      "target": "agent-memory/launch-demo/profile.md"
    },
    {
      "source": "starter/agent-memory/evidence/launch-demo-before.md",
      "target": "agent-memory/evidence/launch-demo-before.md"
    },
    {
      "source": "starter/agent-memory/handoffs/launch-demo-resume-handoff.md",
      "target": "agent-memory/handoffs/launch-demo-resume-handoff.md"
    },
    {
      "source": "starter/agent-memory/reports/launch-demo/project-memory-cockpit.html",
      "target": "agent-memory/reports/launch-demo/project-memory-cockpit.html"
    },
    {
      "source": "templates/launch-demo-next-agent-prompt.md",
      "target": "agent-memory/templates/launch-demo-next-agent-prompt.md"
    },
    {
      "source": "docs/try-owledge-in-5-minutes.md",
      "target": "docs/try-owledge-in-5-minutes.md"
    }
  ],
  "gitignore": [
    "agent-memory/reports/launch-demo/*.local.html"
  ]
}
