{
  "name": "launch-demo-kit",
  "version": "0.1.0",
  "description": "Optional five-minute demo assets that show Owledge durable memory, evidence, handoff, and a static proof report.",
  "install_directories": [
    ".owledge/launch-demo",
    ".owledge/evidence",
    ".owledge/handoffs",
    ".owledge/reports/launch-demo",
    ".owledge/templates"
  ],
  "install_files": [
    {
      "source": "starter/.owledge/launch-demo/profile.md",
      "target": ".owledge/launch-demo/profile.md"
    },
    {
      "source": "starter/.owledge/evidence/launch-demo-before.md",
      "target": ".owledge/evidence/launch-demo-before.md"
    },
    {
      "source": "starter/.owledge/handoffs/launch-demo-resume-handoff.md",
      "target": ".owledge/handoffs/launch-demo-resume-handoff.md"
    },
    {
      "source": "starter/.owledge/reports/launch-demo/project-memory-cockpit.html",
      "target": ".owledge/reports/launch-demo/project-memory-cockpit.html"
    },
    {
      "source": "templates/launch-demo-next-agent-prompt.md",
      "target": ".owledge/templates/launch-demo-next-agent-prompt.md"
    },
    {
      "source": "docs/try-owledge-in-5-minutes.md",
      "target": "docs/try-owledge-in-5-minutes.md"
    }
  ],
  "gitignore": [
    ".owledge/reports/launch-demo/*.local.html"
  ]
}
