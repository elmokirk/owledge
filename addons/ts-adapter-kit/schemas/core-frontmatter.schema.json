{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OwledgeCoreFrontmatter",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "memory_id",
    "tenant_id",
    "customer_id",
    "project_id",
    "doc_type",
    "status",
    "visibility",
    "data_class",
    "semantic_title",
    "summary",
    "concept_tags",
    "stack_tags",
    "problem_patterns",
    "architecture_patterns",
    "failure_modes",
    "reusable_lessons",
    "confidence",
    "review_status",
    "sanitization_status",
    "created_at",
    "updated_at",
    "source_hash",
    "edges"
  ],
  "properties": {
    "memory_id": { "type": "string", "pattern": "^mem:" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "customer_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "doc_type": {
      "type": "string",
      "enum": [
        "project_context",
        "canonical",
        "compiled",
        "pattern",
        "lesson",
        "adr",
        "session",
        "evidence",
        "qa",
        "task",
        "handoff",
        "idea",
        "user_context",
        "preference",
        "goal",
        "daily",
        "personal_task",
        "research",
        "personal_pattern",
        "coach_report",
        "onboarding_profile"
      ]
    },
    "status": { "type": "string", "enum": ["draft", "active", "reviewed", "promoted", "superseded", "archived"] },
    "visibility": { "type": "string", "enum": ["private", "tenant", "customer", "shared"] },
    "data_class": { "type": "string", "enum": ["public", "internal", "confidential", "personal", "special-category"] },
    "semantic_title": { "type": "string" },
    "summary": { "type": "string" },
    "concept_tags": { "type": "array", "items": { "type": "string" } },
    "stack_tags": { "type": "array", "items": { "type": "string" } },
    "problem_patterns": { "type": "array", "items": { "type": "string" } },
    "architecture_patterns": { "type": "array", "items": { "type": "string" } },
    "failure_modes": { "type": "array", "items": { "type": "string" } },
    "reusable_lessons": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "review_status": { "type": "string", "enum": ["unreviewed", "reviewed", "approved", "rejected"] },
    "sanitization_status": { "type": "string", "enum": ["not_required", "pending", "approved", "rejected"] },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "source_hash": { "type": "string" },
    "edges": { "type": "array" }
  }
}
