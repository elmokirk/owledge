{
  "name": "compliance-light",
  "version": "0.1.0",
  "description": "Optional Markdown-first compliance-support add-on for Owledge projects.",
  "install_directories": [
    ".owledge/compliance/registers",
    ".owledge/compliance/dpia",
    ".owledge/compliance/ai-systems",
    ".owledge/compliance/incidents",
    ".owledge/compliance/requests",
    ".owledge/compliance/policies",
    ".owledge/exports/compliance"
  ],
  "install_files": [
    {
      "source": "starter/.owledge/compliance/profile.md",
      "target": ".owledge/compliance/profile.md"
    },
    {
      "source": "templates/processing-activity-template.md",
      "target": ".owledge/templates/processing-activity-template.md"
    },
    {
      "source": "templates/ai-system-template.md",
      "target": ".owledge/templates/ai-system-template.md"
    },
    {
      "source": "templates/provider-registry-template.md",
      "target": ".owledge/templates/provider-registry-template.md"
    },
    {
      "source": "templates/dpia-trigger-template.md",
      "target": ".owledge/templates/dpia-trigger-template.md"
    },
    {
      "source": "templates/data-subject-request-template.md",
      "target": ".owledge/templates/data-subject-request-template.md"
    },
    {
      "source": "templates/security-incident-template.md",
      "target": ".owledge/templates/security-incident-template.md"
    },
    {
      "source": "schemas/compliance-record.schema.json",
      "target": ".owledge/schemas/compliance-record.schema.json"
    },
    {
      "source": "docs/compliance-light.md",
      "target": "docs/compliance-light.md"
    }
  ]
}
