{
  "name": "project-snapshot-kit",
  "version": "0.1.0",
  "description": "Optional Markdown-first project snapshot and static dashboard add-on for Owledge projects.",
  "install_directories": [
    ".owledge/project-snapshot",
    ".owledge/plans"
  ],
  "install_files": [
    {
      "source": "starter/.owledge/project-snapshot/profile.md",
      "target": ".owledge/project-snapshot/profile.md"
    },
    {
      "source": "templates/project-story-snapshot-template.md",
      "target": ".owledge/templates/project-story-snapshot-template.md"
    },
    {
      "source": "templates/project-execution-snapshot-template.md",
      "target": ".owledge/templates/project-execution-snapshot-template.md"
    },
    {
      "source": "templates/project-site-html-template.md",
      "target": ".owledge/templates/project-site-html-template.md"
    },
    {
      "source": "skills/render-memory-report/references/project-site.md",
      "target": "skills/render-memory-report/references/project-site.md"
    },
    {
      "source": "skills/render-memory-report/references/execution-dashboard.md",
      "target": "skills/render-memory-report/references/execution-dashboard.md"
    },
    {
      "source": "docs/project-snapshot-kit.md",
      "target": "docs/project-snapshot-kit.md"
    }
  ],
  "install_if_parent_exists": [
    {
      "parent": "plugins/owledge-cowork",
      "source": "skills/render-memory-report/references/project-site.md",
      "target": "plugins/owledge-cowork/skills/render-memory-report/references/project-site.md"
    },
    {
      "parent": "plugins/owledge-cowork",
      "source": "skills/render-memory-report/references/execution-dashboard.md",
      "target": "plugins/owledge-cowork/skills/render-memory-report/references/execution-dashboard.md"
    }
  ],
  "gitignore": [
    ".owledge/project-snapshot/project-snapshot-manifest.json",
    ".owledge/reports/project-site/"
  ]
}
